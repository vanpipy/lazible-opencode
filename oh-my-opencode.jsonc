{
  // Oh-My-OpenAgent configuration for this OpenCode setup.
  // -----------------------------------------------------
  // This file defines:
  // - Agents: concrete personas you can select (sisyphus, hephaestus, librarian, ...).
  // - Categories: abstract routing tiers (quick, ultrabrain, writing, ...) that decide
  //   which model profile to use for a given kind of task.
  //
  // Design goals:
  // - Keep agents minimal so they inherit model/cost policies from categories.
  // - Centralize "cost / latency / quality" decisions in categories only.
  // - Make it easy to add a second or third model later without touching each agent.
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // Agents: WHO is doing the work (persona / role).
  // Agents can have their own prompts, tools and permissions (configured in oh-my-openagent
  // defaults and opencode.json). Here we only register the names; we let categories decide
  // which model tier they run on.
  "agents": {
    // Primary orchestrator for complex, multi-step coding tasks.
    // Good default when you want decomposition + tool usage.
    "sisyphus": {},

    // Code-focused builder / refactorer.
    // Use this when you mainly want high-quality implementations and edits.
    "hephaestus": {},

    // Reasoning and explanation specialist.
    // Helpful for validating plans, explaining code, or checking subtle logic.
    "oracle": {},

    // Knowledge / documentation specialist.
    // Best for searching, summarizing, and navigating large doc sets.
    "librarian": {},

    // Repository / workspace explorer.
    // Helps map project structure, entrypoints, and cross-file relationships.
    "explore": {},

    // Multimodal / visual inspector.
    // When a vision-capable model is bound via categories, this agent can use it.
    "multimodal-looker": {},

    // Strategy and high-level planning.
    // Good for turning vague goals into prioritized task lists.
    "prometheus": {},

    // Meta-analyst for decomposition and prioritization.
    // Use this to decide what to do first and where the highest leverage is.
    "metis": {},

    // Critic / reviewer.
    // Useful for code review, spec review, and "red team" feedback.
    "momus": {},

    // Large-workspace navigator.
    // Focused on cross-file patterns and large-scale refactors.
    "atlas": {},

    // Lightweight orchestrator.
    // Similar to sisyphus but tuned for slightly cheaper/faster coordination when available.
    "sisyphus-junior": {}
  },

  // Categories: HOW the work should be run (routing tier).
  // Categories express preferences like:
  // - fast vs deep
  // - cheap vs high-quality
  // - general vs writing vs visual
  //
  // Recommended evolution plan:
  // - When you add a small/cheap model: bind `quick` and `unspecified-low` to that model.
  // - When you add a strong reasoning model: bind `ultrabrain` and `deep` to it.
  // - When you add a vision-capable model: bind `visual-engineering` to that model.
  //
  // For now, all categories point to the same DeepSeek model for simplicity.
  "categories": {
    // Visual and multimodal engineering workflows.
    // Set this to a vision-capable model when you have one.
    "visual-engineering": {
      "model": "deepseek/deepseek-chat"
    },

    // Highest-quality reasoning tier.
    // Use this for the most difficult, correctness-critical tasks.
    "ultrabrain": {
      "model": "deepseek/deepseek-chat"
    },

    // Deep analysis / long-context tasks.
    // Can share the same model as `ultrabrain` or point to a long-context variant.
    "deep": {
      "model": "deepseek/deepseek-chat"
    },

    // Creative and editorial workflows (code comments, UI copy, content drafts, etc.).
    "artistry": {
      "model": "deepseek/deepseek-chat"
    },

    // Fast / low-cost tier.
    // Ideal target when you introduce a smaller, cheaper model.
    "quick": {
      "model": "deepseek/deepseek-chat"
    },

    // Generic low-priority routing (background or non-critical tasks).
    "unspecified-low": {
      "model": "deepseek/deepseek-chat"
    },

    // Generic high-priority routing (quality over cost).
    "unspecified-high": {
      "model": "deepseek/deepseek-chat"
    },

    // Long-form writing, editing and formatting.
    // Good place to bind a model optimized for text generation when available.
    "writing": {
      "model": "deepseek/deepseek-chat"
    }
  }
}
