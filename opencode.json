{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "apiKey": "{env:OPENCODE_MODEL_API_KEY}",
        "timeout": 600000,
        "chunkTimeout": 30000
      },
      "models": {
        "deepseek-chat": {
          "name": "deepseek-chat",
          "options": {
            "temperature": 0.2,
            "maxTokens": 2048
          },
          "limit": {
            "context": 128000,
            "output": 2048
          }
        }
      }
    }
  },
  "model": "deepseek/deepseek-chat",
  "small_model": "deepseek/deepseek-chat",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "deepseek/deepseek-chat",
      "prompt": "You are an AI coding assistant running on DeepSeek (deepseek-chat) via an OpenAI-compatible API.\nWrite clean, efficient code with proper error handling.\nUse Chinese if the user's code comments are in Chinese, otherwise use English.",
      "temperature": 0.3,
      "permission": {
        "edit": "allow",
        "bash": {
          "rm": "ask",
          "trash": "ask"
        }
      }
    },
    "plan": {
      "mode": "primary",
      "model": "deepseek/deepseek-chat",
      "prompt": "You are an AI coding assistant running on DeepSeek (deepseek-chat) via an OpenAI-compatible API.\nThink step by step and explain your plan clearly.\nDo not make file edits unless asked.\nUse Chinese if the user's code comments are in Chinese, otherwise use English.",
      "temperature": 0.7,
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    }
  },
  "autoupdate": "notify",
  "snapshot": false,
  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      ".pnpm-store/**",
      ".yarn/**",
      ".npm/**",
      ".cache/**",
      "dist/**",
      "build/**",
      ".next/**",
      ".nuxt/**",
      ".output/**",
      "coverage/**",
      "target/**",
      "vendor/**",
      ".venv/**",
      "venv/**",
      "__pycache__/**",
      "*.sqlite",
      "*.sqlite3",
      "*.db",
      "*.duckdb",
      "*.parquet",
      "*.arrow",
      "*.feather",
      "*.csv",
      "*.tsv",
      "*.xlsx",
      "*.bin",
      "*.onnx",
      "*.pt",
      "*.pth",
      "*.ckpt",
      "*.safetensors",
      "*.log",
      "*.zip",
      "*.tar",
      "*.tar.gz",
      "*.gz",
      "*.7z",
      "*.mp4",
      "*.mov",
      "*.mkv",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.gif",
      "*.webp",
      "*.pdf"
    ]
  },
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git#v5.0.6",
    "oh-my-openagent@git+https://github.com/code-yeongyu/oh-my-openagent.git#v3.14.0"
  ]
}
