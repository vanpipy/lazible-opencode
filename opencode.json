{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "timeout": 600000,
        "chunkTimeout": 30000
      },
      "models": {
        "deepseek-chat": {
          "name": "deepseek-chat",
          "options": {
            "temperature": 0.2,
            "maxTokens": 2048
          },
          "limit": {
            "context": 128000,
            "output": 2048
          }
        }
      }
    },
    "minimax-cn-coding-plan": {
      "npm": "@ai-sdk/anthropic",
      "name": "MiniMax Coding Plan",
      "options": {
        "baseURL": "https://api.minimaxi.com/anthropic/v1",
        "timeout": 600000,
        "chunkTimeout": 120000
      },
      "models": {
        "MiniMax-M2.5": {
          "name": "MiniMax-M2.5",
          "options": {
            "maxTokens": 8192
          },
          "limit": {
            "context": 100000,
            "output": 8192
          }
        },
        "MiniMax-M2.7": {
          "name": "MiniMax-M2.7",
          "options": {
            "maxTokens": 8192,
            "reasoning_split": false
          },
          "limit": {
            "context": 100000,
            "output": 8192
          }
        }
      }
    }
  },
  "model": "minimax-cn-coding-plan/MiniMax-M2.7",
  "small_model": "minimax-cn-coding-plan/MiniMax-M2.7",
  "autoupdate": "notify",
  "snapshot": false,
  "formatter": {
    "biome": {
      "command": ["npx", "biome", "format", "--write", "$FILE"],
      "extensions": [".js", ".jsx", ".ts", ".tsx", ".json", ".jsonc"]
    }
  },
  "permission": {
    "read": {
      ".env": "allow",
      ".env.*": "allow",
      ".env-*": "allow"
    },
    "external_directory": "allow",
    "bash": {
      "git push": "allow",
      "git push *": "allow",
      "sudo *": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      ":(){:|:&};:": "deny"
    }
  },
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    }
  },
  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      ".pnpm-store/**",
      ".yarn/**",
      ".npm/**",
      ".cache/**",
      "dist/**",
      "build/**",
      ".next/**",
      ".nuxt/**",
      ".output/**",
      "coverage/**",
      "target/**",
      "vendor/**",
      ".venv/**",
      "venv/**",
      "__pycache__/**",
      "*.sqlite",
      "*.sqlite3",
      "*.db",
      "*.duckdb",
      "*.parquet",
      "*.arrow",
      "*.feather",
      "*.csv",
      "*.tsv",
      "*.xlsx",
      "*.bin",
      "*.onnx",
      "*.pt",
      "*.pth",
      "*.ckpt",
      "*.safetensors",
      "*.log",
      "*.zip",
      "*.tar",
      "*.tar.gz",
      "*.gz",
      "*.7z",
      "*.mp4",
      "*.mov",
      "*.mkv",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.gif",
      "*.webp",
      "*.pdf"
    ]
  },
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "@broskees/opencode-codebase-graph",
    "swarm"
  ],
  "mcp": {
    "MiniMax": {
      "type": "local",
      "command": ["uvx", "minimax-coding-plan-mcp", "-y"],
      "environment": {
        "MINIMAX_API_KEY": "{env:MINIMAX_API_KEY}",
        "MINIMAX_API_HOST": "https://api.minimaxi.com"
      },
      "enabled": true
    },
    "next-devtools": {
      "type": "local",
      "command": ["npx", "-y", "next-devtools-mcp@latest"]
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "fetch": {
      "type": "local",
      "command": ["uvx", "mcp-server-fetch"]
    }
  }
}
