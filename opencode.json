{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "timeout": 600000,
        "chunkTimeout": 30000
      },
      "models": {
        "deepseek-chat": {
          "name": "deepseek-chat",
          "options": {
            "temperature": 0.2,
            "maxTokens": 2048
          },
          "limit": {
            "context": 128000,
            "output": 2048
          }
        }
      }
    },
    "minimax-cn-coding-plan": {
      "npm": "@ai-sdk/anthropic",
      "name": "MiniMax Coding Plan",
      "options": {
        "baseURL": "https://api.minimaxi.com/anthropic/v1",
        "timeout": 600000,
        "chunkTimeout": 120000
      },
      "models": {
        "MiniMax-M1": {
          "name": "MiniMax-M1",
          "options": {
            "temperature": 0.2,
            "maxTokens": 4096
          },
          "limit": {
            "context": 32000,
            "output": 4096
          }
        },
        "MiniMax-M2.5": {
          "name": "MiniMax-M2.5",
          "options": {
            "temperature": 0.2,
            "maxTokens": 8192
          },
          "limit": {
            "context": 100000,
            "output": 8192
          }
        },
        "MiniMax-M2.7": {
          "name": "MiniMax-M2.7",
          "options": {
            "temperature": 0.2,
            "maxTokens": 8192,
            "reasoning_split": false
          },
          "limit": {
            "context": 100000,
            "output": 8192
          }
        },
        "MiniMax-M2.7-highspeed": {
          "name": "MiniMax-M2.7-highspeed",
          "options": {
            "temperature": 0.2,
            "maxTokens": 8192
          },
          "limit": {
            "context": 100000,
            "output": 8192
          }
        }
      }
    }
  },
  "model": "minimax-cn-coding-plan/MiniMax-M2.7",
  "small_model": "minimax-cn-coding-plan/MiniMax-M2.7",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "minimax-cn-coding-plan/MiniMax-M2.7",
      "prompt": "You are an AI coding assistant. Write clean, efficient code with proper error handling. Use Chinese if the user's code comments are in Chinese, otherwise use English.",
      "temperature": 0.3,
      "permission": {
        "edit": "allow",
        "bash": {
          "rm": "ask",
          "trash": "ask"
        }
      }
    },
    "plan": {
      "mode": "primary",
      "model": "minimax-cn-coding-plan/MiniMax-M2.7",
      "prompt": "You are an AI coding assistant. Think step by step and explain your plan clearly. Do not make file edits unless asked. Use Chinese if the user's code comments are in Chinese, otherwise use English.",
      "temperature": 0.7,
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    },
    "review": {
      "description": "Role: Senior Auditor & Auto-Fix Expert. [Inherit: Momus Critique]. [Action]: Audit for security/logic and fix via file_write.",
      "mode": "subagent",
      "model": "minimax-cn-coding-plan/MiniMax-M2.5",
      "temperature": 0.2,
      "steps": 8,
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "deny",
        "task": { "*": "allow" }
      }
    }
  },
  "autoupdate": "notify",
  "snapshot": false,
  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      ".pnpm-store/**",
      ".yarn/**",
      ".npm/**",
      ".cache/**",
      "dist/**",
      "build/**",
      ".next/**",
      ".nuxt/**",
      ".output/**",
      "coverage/**",
      "target/**",
      "vendor/**",
      ".venv/**",
      "venv/**",
      "__pycache__/**",
      "*.sqlite",
      "*.sqlite3",
      "*.db",
      "*.duckdb",
      "*.parquet",
      "*.arrow",
      "*.feather",
      "*.csv",
      "*.tsv",
      "*.xlsx",
      "*.bin",
      "*.onnx",
      "*.pt",
      "*.pth",
      "*.ckpt",
      "*.safetensors",
      "*.log",
      "*.zip",
      "*.tar",
      "*.tar.gz",
      "*.gz",
      "*.7z",
      "*.mp4",
      "*.mov",
      "*.mkv",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.gif",
      "*.webp",
      "*.pdf"
    ]
  },
  "plugin": [
    "oh-my-openagent",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "@broskees/opencode-codebase-graph"
  ],
  "mcp": {
    "MiniMax": {
      "type": "local",
      "command": ["uvx", "minimax-coding-plan-mcp", "-y"],
      "environment": {
        "MINIMAX_API_KEY": "{env:MINIMAX_API_KEY}",
        "MINIMAX_API_HOST": "https://api.minimaxi.com"
      },
      "enabled": true
    }
  }
}
