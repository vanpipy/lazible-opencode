{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    // --- 攻坚手：使用最新的 M2.7 ---
    "hephaestus": { "model": "minimax/MiniMax-M2.7" }, // 负责最难的重构
    "prometheus": { "model": "minimax/MiniMax-M2.7" }, // 负责复杂的需求规划

    // --- 深度审计：继续由 M1 担任 ---
    "momus": {
      "model": "minimax/MiniMax-M1",
      "prompt": "Role: Senior Auditor. [Logic]: Use deep CoT to find bugs. [Action]: For every bug, you MUST output a block: 'FIX_SUGGESTION: [code...]'. Your goal is to provide these blocks so Sisyphus can apply them."
    },

    // --- 稳定基座：使用 M2.5 负责日常任务 ---
    "sisyphus": { "model": "minimax/MiniMax-M2.5" }, // 主编排器用 M2.5，保证长时间对话不崩
    "explore": { "model": "minimax/MiniMax-M2.5" },  // 搜索代码库，M2.5 的稳定性非常合适
    "metis": { "model": "minimax/MiniMax-M2.5" },    // 逻辑评估
    "librarian": { "model": "minimax/MiniMax-M2.5" }, // 查阅文档

    "atlas": { "model": "minimax/MiniMax-M2.5" },
    "oracle": { "model": "minimax/MiniMax-M1" }
  },

  "categories": {
    "deep": { "model": "minimax/MiniMax-M1" },
    "quick": { "model": "minimax/MiniMax-M2.5" }, // M2.5 响应也很快
    "unspecified-high": { "model": "minimax/MiniMax-M2.7" } // 只有明确要求高质量时才切到 M2.7
  },

  "experimental": {
    "dcp_for_compaction": true,
    "native_file_watcher": true
  },

  "comment_checker": {
    "custom_prompt": "Audit for critical logical bugs and security vulnerabilities. Respond with concise, concrete fix suggestions. Ignore style and formatting."
  }
}
