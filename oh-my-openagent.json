{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "hephaestus": { "model": "minimax-cn-coding-plan/MiniMax-M2.7" },
    "prometheus": { "model": "minimax-cn-coding-plan/MiniMax-M2.7" },

    "momus": {
      "model": "minimax-cn-coding-plan/MiniMax-M2.7",
      "prompt": "Role: Senior Auditor & Auto-Fix Expert. [Inherit: Momus Critique]. [Action]: Audit for security/logic and pass issues to sisyphus to fix."
    },

    "sisyphus": { "model": "minimax-cn-coding-plan/MiniMax-M2.5" },
    "explore": { "model": "minimax-cn-coding-plan/MiniMax-M2.5" },
    "metis": { "model": "minimax-cn-coding-plan/MiniMax-M2.5" },
    "librarian": { "model": "minimax-cn-coding-plan/MiniMax-M2.5" },

    "atlas": { "model": "minimax-cn-coding-plan/MiniMax-M2.5" },
    "oracle": { "model": "minimax-cn-coding-plan/MiniMax-M1" }
  },

  "categories": {
    "deep": { "model": "minimax-cn-coding-plan/MiniMax-M1" },
    "quick": { "model": "minimax-cn-coding-plan/MiniMax-M2.5" },

    "hephaestus": { "model": "minimax-cn-coding-plan/MiniMax-M2.7" },
    "prometheus": { "model": "minimax-cn-coding-plan/MiniMax-M2.7" },

    "momus": { "model": "minimax-cn-coding-plan/MiniMax-M2.7" },

    "sisyphus": { "model": "minimax-cn-coding-plan/MiniMax-M2.5" },
    "explore": { "model": "minimax-cn-coding-plan/MiniMax-M2.5" },
    "metis": { "model": "minimax-cn-coding-plan/MiniMax-M2.5" },
    "librarian": { "model": "minimax-cn-coding-plan/MiniMax-M2.5" },

    "atlas": { "model": "minimax-cn-coding-plan/MiniMax-M2.5" },
    "oracle": { "model": "minimax-cn-coding-plan/MiniMax-M2.7" }
  },

  "experimental": {
    "dcp_for_compaction": true,
    "native_file_watcher": true
  },

  "comment_checker": {
    "custom_prompt": "Audit for critical logical bugs and security vulnerabilities. Respond with concise, concrete fix suggestions. Ignore style and formatting."
  }
}
